---
interface Props {
  weekStats: {
    days: number;
    volume: string;
    sets: number;
    topMuscle: string;
    prs: number;
    uniqueExercises: number;
    streak: number;
    bestLift: { name: string; weight: number; reps: number } | null;
    weekLabel: string;
  };
  userName: string;
}
const { weekStats, userName } = Astro.props;
---

<div id="rewind-banner" class="rewind-banner" aria-hidden="true">
  <button class="rewind-dismiss" id="rewind-dismiss" aria-label="Cerrar">×</button>
  <div class="rewind-inner">
    <div class="rewind-icon">◆</div>
    <div class="rewind-content">
      <div class="rewind-heading">REWIND SEMANAL</div>
      <div class="rewind-week">{weekStats.weekLabel}</div>
      <div class="rewind-mini-stats">
        <span><strong>{weekStats.days}</strong> días</span>
        <span class="sep">·</span>
        <span><strong>{weekStats.volume}t</strong> vol</span>
        <span class="sep">·</span>
        <span><strong>{weekStats.sets}</strong> series</span>
      </div>
    </div>
    <button class="rewind-btn" id="rewind-generate">
      <span class="rewind-shimmer-line"></span>
      <span class="rewind-btn-text">COMPARTIR</span>
    </button>
  </div>
</div>

<!-- Preview modal -->
<div id="rewind-preview" class="rw-preview" aria-hidden="true" aria-modal="true" role="dialog">
  <button class="rw-preview-close" id="rw-preview-close" aria-label="Cerrar">×</button>
  <div class="rw-preview-inner">
    <img id="rw-preview-img" class="rw-preview-img" src="" alt="Vista previa Rewind" />
    <div class="rw-preview-actions">
      <button id="rw-download-btn" class="rw-action-btn rw-action-secondary">
        <span class="rw-action-icon">↓</span> DESCARGAR
      </button>
      <button id="rw-share-btn" class="rw-action-btn rw-action-primary">
        <span class="rw-action-icon">↑</span> COMPARTIR
      </button>
    </div>
  </div>
</div>

<style is:global>
  .rewind-banner {
    display: none;
    position: relative;
    margin: var(--space-4) 0;
    padding: 1.5px;
    border-radius: 10px;
    background: linear-gradient(90deg, #30d158 0%, #ff9500 50%, #30d158 100%);
    background-size: 200% 100%;
    animation: rewind-border-slide 3s linear infinite;
  }
  @keyframes rewind-border-slide {
    0%   { background-position: 0% 0%; }
    100% { background-position: 200% 0%; }
  }
  .rewind-inner {
    background: var(--bg-secondary);
    border-radius: 9px;
    padding: var(--space-3) var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .rewind-dismiss {
    position: absolute;
    top: 6px; right: 8px;
    background: none; border: none;
    color: var(--text-muted);
    font-size: 1.1rem; line-height: 1;
    padding: 2px 6px; cursor: pointer; z-index: 1;
    transition: color var(--transition-fast);
  }
  .rewind-dismiss:hover { color: var(--text-primary); }
  .rewind-icon {
    font-size: 1.4rem; color: var(--accent-green);
    flex-shrink: 0;
    animation: rewind-icon-pulse 2s ease infinite;
  }
  @keyframes rewind-icon-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(0.85); }
  }
  .rewind-content { flex: 1; min-width: 0; }
  .rewind-heading {
    font-family: var(--font-display);
    font-size: 0.65rem; letter-spacing: 2px;
    color: var(--accent-green); margin-bottom: 2px;
  }
  .rewind-week { font-size: 0.62rem; color: var(--text-muted); margin-bottom: 4px; }
  .rewind-mini-stats {
    font-size: 0.7rem; color: var(--text-secondary);
    display: flex; gap: var(--space-2); flex-wrap: wrap;
  }
  .rewind-mini-stats strong { color: var(--text-primary); }
  .rewind-mini-stats .sep   { color: var(--border-light); }
  .rewind-btn {
    position: relative; overflow: hidden;
    font-family: var(--font-display);
    font-size: 0.62rem; letter-spacing: 1.5px;
    background: var(--accent-green); color: var(--text-dark);
    border: none; border-radius: 6px;
    padding: var(--space-2) var(--space-3);
    cursor: pointer; flex-shrink: 0;
    transition: opacity var(--transition-fast);
  }
  .rewind-btn:hover    { opacity: 0.88; }
  .rewind-btn:disabled { opacity: 0.45; cursor: not-allowed; }
  .rewind-shimmer-line {
    position: absolute; inset: 0;
    background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.35) 50%, transparent 60%);
    background-size: 200% 100%;
    animation: rewind-shimmer 2.2s ease infinite;
  }
  .rewind-btn:disabled .rewind-shimmer-line { display: none; }
  @keyframes rewind-shimmer {
    0%   { background-position: -100% 0; }
    100% { background-position: 200% 0; }
  }

  /* ── Preview modal ─────────────────────────────────────────── */
  .rw-preview {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 2000;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    animation: rw-fade-in 200ms ease;
  }
  .rw-preview.open { display: flex; }

  @keyframes rw-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .rw-preview-close {
    position: fixed;
    top: var(--space-4);
    right: var(--space-4);
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    border-radius: 50%;
    color: var(--text-secondary);
    width: 40px;
    height: 40px;
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
    z-index: 10;
  }
  .rw-preview-close:hover {
    border-color: var(--text-muted);
    color: var(--text-primary);
  }

  .rw-preview-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    max-height: 100vh;
    width: 100%;
    max-width: 420px;
  }

  .rw-preview-img {
    width: auto;
    max-height: 72vh;
    aspect-ratio: 9 / 16;
    border-radius: 10px;
    border: 1px solid var(--border);
    box-shadow: 0 0 60px rgba(0, 0, 0, 0.8);
    object-fit: cover;
    animation: rw-img-in 250ms ease;
  }

  @keyframes rw-img-in {
    from { opacity: 0; transform: scale(0.96); }
    to   { opacity: 1; transform: scale(1); }
  }

  .rw-preview-actions {
    display: flex;
    gap: var(--space-3);
    width: 100%;
  }

  .rw-action-btn {
    flex: 1;
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 1.5px;
    padding: var(--space-3) var(--space-4);
    border-radius: 8px;
    cursor: pointer;
    border: 1px solid;
    transition: opacity var(--transition-fast);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
  }
  .rw-action-btn:hover    { opacity: 0.8; }
  .rw-action-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .rw-action-secondary {
    background: transparent;
    color: var(--text-primary);
    border-color: var(--border-light);
  }
  .rw-action-primary {
    background: var(--accent-green);
    color: var(--text-dark);
    border-color: var(--accent-green);
  }

  .rw-action-icon { font-size: 1rem; line-height: 1; }
</style>

<script define:vars={{ weekStats, userName }}>
  const banner      = document.getElementById('rewind-banner');
  const dismissBtn  = document.getElementById('rewind-dismiss');
  const generateBtn = document.getElementById('rewind-generate');
  const btnText     = generateBtn.querySelector('.rewind-btn-text');

  const isSaturday = new Date().getDay() === 6;
  const isTest     = new URLSearchParams(location.search).has('rewind');
  const dismissKey = 'rewind-dismissed-' + weekStats.weekLabel;

  if ((isSaturday || isTest) && !localStorage.getItem(dismissKey)) {
    banner.style.display = 'block';
    banner.removeAttribute('aria-hidden');
  }

  dismissBtn.addEventListener('click', () => {
    localStorage.setItem(dismissKey, '1');
    banner.style.display = 'none';
  });

  generateBtn.addEventListener('click', async () => {
    generateBtn.disabled = true;
    btnText.textContent  = 'GENERANDO...';
    try {
      const result = await generateRewindImage();
      showPreview(result.dataUrl, result.blob);
    } finally {
      generateBtn.disabled = false;
      btnText.textContent  = 'COMPARTIR';
    }
  });

  function showPreview(dataUrl, blob) {
    const modal       = document.getElementById('rewind-preview');
    const img         = document.getElementById('rw-preview-img');
    const closeBtn    = document.getElementById('rw-preview-close');
    const downloadBtn = document.getElementById('rw-download-btn');
    const shareBtn    = document.getElementById('rw-share-btn');

    img.src = dataUrl;
    modal.classList.add('open');
    modal.removeAttribute('aria-hidden');

    const filename = 'gymapp-rewind-' + weekStats.weekLabel.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase() + '.jpg';

    // Mostrar botón compartir solo si el browser lo soporta con archivos
    var canShare = !!(navigator.share && navigator.canShare &&
      navigator.canShare({ files: [new File([], 'x.jpg', { type: 'image/jpeg' })] }));
    shareBtn.style.display = canShare ? '' : 'none';
    if (!canShare) downloadBtn.style.flex = '1 1 100%';

    downloadBtn.onclick = () => {
      var a = document.createElement('a');
      a.href = dataUrl; a.download = filename;
      document.body.appendChild(a); a.click(); document.body.removeChild(a);
    };

    shareBtn.onclick = async () => {
      var file = new File([blob], filename, { type: 'image/jpeg' });
      try { await navigator.share({ files: [file], title: 'Mi Rewind Semanal · GymApp' }); }
      catch (_) { /* usuario canceló */ }
    };

    function close() {
      modal.classList.remove('open');
      modal.setAttribute('aria-hidden', 'true');
      img.src = '';
    }
    closeBtn.onclick = close;
    modal.onclick = (e) => { if (e.target === modal) close(); };
  }

  // ─────────────────────────────────────────────────────────────
  //  8 FIXED ZONES — nothing overflows, all info included
  //
  //  Z1  HEADER          y  0 – 358
  //  Z2  HERO DÍAS       y  362 – 648
  //  Z3  VOLUMEN|SERIES  y  648 – 866   (card bg)
  //  Z4  RACHA|EJERC.    y  866 – 1086
  //  Z5  MÚSCULO         y  1086 – 1308 (card bg)
  //  Z6  RÉCORDS         y  1308 – 1500
  //  Z7  MEJOR SERIE     y  1500 – 1730 (card bg)
  //  Z8  FOOTER          y  1730 – 1920
  // ─────────────────────────────────────────────────────────────
  async function generateRewindImage() {
    await document.fonts.ready;

    const W = 1080, H = 1920;
    const canvas = document.createElement('canvas');
    canvas.width = W; canvas.height = H;
    const ctx = canvas.getContext('2d');

    // helpers
    function hline(y, color, margin) {
      ctx.strokeStyle = color || '#1e1e1e'; ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(margin || 90, y); ctx.lineTo(W - (margin || 90), y);
      ctx.stroke();
    }
    function vline(x, y0, y1) {
      ctx.strokeStyle = '#1a1a1a'; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(x, y0); ctx.lineTo(x, y1); ctx.stroke();
    }
    function cardBg(y0, h) {
      ctx.fillStyle = '#0e0e0e'; ctx.fillRect(0, y0, W, h);
    }
    function drawPill(label, cy, fg, bg, border, fsize) {
      ctx.font = 'bold ' + (fsize || 44) + 'px Orbitron, monospace';
      const tw = ctx.measureText(label).width;
      const ph = 80, pw = tw + 60, px = (W - pw) / 2, pr = 10;
      ctx.fillStyle = bg;
      ctx.beginPath();
      ctx.moveTo(px+pr, cy-ph/2); ctx.lineTo(px+pw-pr, cy-ph/2);
      ctx.arcTo(px+pw, cy-ph/2, px+pw, cy-ph/2+pr, pr);
      ctx.lineTo(px+pw, cy+ph/2-pr);
      ctx.arcTo(px+pw, cy+ph/2, px+pw-pr, cy+ph/2, pr);
      ctx.lineTo(px+pr, cy+ph/2);
      ctx.arcTo(px, cy+ph/2, px, cy+ph/2-pr, pr);
      ctx.lineTo(px, cy-ph/2+pr);
      ctx.arcTo(px, cy-ph/2, px+pr, cy-ph/2, pr);
      ctx.closePath();
      ctx.fill();
      ctx.strokeStyle = border; ctx.lineWidth = 1; ctx.stroke();
      ctx.fillStyle = fg;
      ctx.textBaseline = 'middle'; ctx.fillText(label, W/2, cy);
      ctx.textBaseline = 'alphabetic';
    }
    function statCol(val, lbl, x, cy) {
      ctx.textBaseline = 'middle';
      ctx.fillStyle = '#ffffff';
      ctx.font = 'bold 76px Orbitron, monospace';
      ctx.fillText(val, x, cy - 22);
      ctx.fillStyle = '#484848';
      ctx.font = '20px "Space Grotesk", monospace';
      ctx.fillText(lbl, x, cy + 48);
      ctx.textBaseline = 'alphabetic';
    }
    function truncate(text, maxW) {
      ctx.font = '28px "Space Grotesk", monospace';
      if (ctx.measureText(text).width <= maxW) return text;
      while (text.length > 1 && ctx.measureText(text + '…').width > maxW)
        text = text.slice(0, -1);
      return text + '…';
    }
    function bracket(ox, oy, fx, fy) {
      const s = 68, p = 54, sx = fx ? -1 : 1, sy = fy ? -1 : 1;
      ctx.save(); ctx.translate(ox, oy);
      ctx.strokeStyle = '#30d158'; ctx.lineWidth = 3; ctx.lineCap = 'square';
      ctx.beginPath();
      ctx.moveTo(sx*(p+s), sy*p); ctx.lineTo(sx*p, sy*p); ctx.lineTo(sx*p, sy*(p+s));
      ctx.stroke(); ctx.restore();
    }

    // ── BACKGROUND ───────────────────────────────────────────────
    ctx.fillStyle = '#0a0a0a'; ctx.fillRect(0, 0, W, H);
    ctx.fillStyle = '#141414';
    for (let x = 54; x < W; x += 54)
      for (let y = 54; y < H; y += 54) {
        ctx.beginPath(); ctx.arc(x, y, 1.5, 0, Math.PI*2); ctx.fill();
      }
    bracket(0,0,false,false); bracket(W,0,true,false);
    bracket(0,H,false,true);  bracket(W,H,true,true);
    ctx.textAlign = 'center'; ctx.textBaseline = 'alphabetic';

    // ── Z1 · HEADER  (0 – 358) ───────────────────────────────────
    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 52px Orbitron, monospace';
    ctx.fillText('GYMAPP', W/2, 228);
    ctx.fillStyle = '#30d158';
    ctx.beginPath(); ctx.arc(W/2 + 168, 212, 8, 0, Math.PI*2); ctx.fill();

    ctx.fillStyle = '#444444';
    ctx.font = '22px "Space Grotesk", monospace';
    ctx.fillText('REWIND SEMANAL', W/2, 294);
    ctx.fillStyle = '#2a2a2a';
    ctx.font = '20px "Space Grotesk", monospace';
    ctx.fillText(weekStats.weekLabel, W/2, 336);

    hline(362, '#30d158', 80);

    // ── Z2 · HERO DÍAS  (362 – 648) ──────────────────────────────
    var glow = ctx.createRadialGradient(W/2, 490, 0, W/2, 490, 300);
    glow.addColorStop(0, 'rgba(48,209,88,0.13)');
    glow.addColorStop(1, 'rgba(48,209,88,0)');
    ctx.fillStyle = glow; ctx.fillRect(0, 362, W, 286);

    ctx.fillStyle = '#30d158';
    ctx.font = 'bold 170px Orbitron, monospace';
    ctx.textBaseline = 'middle';
    ctx.fillText(weekStats.days.toString(), W/2, 488);
    ctx.textBaseline = 'alphabetic';
    ctx.fillStyle = '#585858';
    ctx.font = 'bold 24px Orbitron, monospace';
    ctx.fillText('DÍAS ENTRENADOS', W/2, 604);

    hline(648);

    // ── Z3 · VOLUMEN | SERIES  (648 – 866) ───────────────────────
    cardBg(648, 218);
    statCol(weekStats.volume + 't', 'VOLUMEN',  W/4,   757);
    vline(W/2, 668, 856);
    statCol(weekStats.sets + '',    'SERIES',   W*3/4, 757);
    hline(866);

    // ── Z4 · RACHA | EJERCICIOS  (866 – 1086) ────────────────────
    statCol(weekStats.streak + '',          'RACHA',       W/4,   976);
    vline(W/2, 886, 1076);
    statCol(weekStats.uniqueExercises + '', 'EJERCICIOS',  W*3/4, 976);
    hline(1086);

    // ── Z5 · MÚSCULO DESTACADO  (1086 – 1308) ────────────────────
    cardBg(1086, 222);
    ctx.fillStyle = '#353535';
    ctx.font = '20px "Space Grotesk", monospace';
    ctx.fillText('MÚSCULO DESTACADO', W/2, 1152);
    if (weekStats.topMuscle)
      drawPill(weekStats.topMuscle.toUpperCase(), 1222, '#ff9500', '#160c00', '#ff9500', 48);
    hline(1308);

    // ── Z6 · RÉCORDS  (1308 – 1500) ──────────────────────────────
    if (weekStats.prs > 0) {
      var prLbl = weekStats.prs === 1 ? '1 RÉCORD NUEVO' : weekStats.prs + ' RÉCORDS NUEVOS';
      drawPill(prLbl, 1400, '#30d158', '#071510', '#30d158', 40);
    } else {
      ctx.fillStyle = '#252525';
      ctx.font = '20px "Space Grotesk", monospace';
      ctx.fillText('Sin récords esta semana · ¡A por la próxima!', W/2, 1408);
    }
    hline(1500);

    // ── Z7 · MEJOR SERIE  (1500 – 1730) ──────────────────────────
    cardBg(1500, 230);
    ctx.fillStyle = '#303030';
    ctx.font = '20px "Space Grotesk", monospace';
    ctx.fillText('MEJOR SERIE', W/2, 1562);

    if (weekStats.bestLift && weekStats.bestLift.weight > 0) {
      var bl = weekStats.bestLift;
      ctx.fillStyle = '#606060';
      ctx.font = '28px "Space Grotesk", monospace';
      ctx.fillText(truncate(bl.name, W - 160), W/2, 1618);
      ctx.fillStyle = '#ffffff';
      ctx.font = 'bold 60px Orbitron, monospace';
      ctx.textBaseline = 'middle';
      ctx.fillText(bl.weight + 'kg × ' + bl.reps, W/2, 1672);
      ctx.textBaseline = 'alphabetic';
    } else {
      ctx.fillStyle = '#252525';
      ctx.font = '22px "Space Grotesk", monospace';
      ctx.fillText('—', W/2, 1640);
    }
    hline(1730);

    // ── Z8 · FOOTER  (1730 – 1920) ───────────────────────────────
    hline(1762, '#30d158', 80);
    if (userName) {
      ctx.fillStyle = '#363636';
      ctx.font = '26px "Space Grotesk", monospace';
      ctx.fillText(userName, W/2, 1832);
    }
    ctx.fillStyle = '#212121';
    ctx.font = '20px "Space Grotesk", monospace';
    ctx.fillText('Tu progreso, tu récord · GymApp', W/2, 1876);

    // ── RETURN dataUrl + blob ────────────────────────────────────
    var dataUrl = canvas.toDataURL('image/jpeg', 0.93);
    var blob = await new Promise(function(resolve) {
      canvas.toBlob(resolve, 'image/jpeg', 0.93);
    });
    return { dataUrl: dataUrl, blob: blob };
  }
</script>
