---
interface Props {
  weekStats: {
    days: number;
    volume: string;
    sets: number;
    topMuscle: string;
    prs: number;
    uniqueExercises: number;
    streak: number;
    bestLift: { name: string; weight: number; reps: number } | null;
    weekLabel: string;
  };
  userName: string;
}
const { weekStats, userName } = Astro.props;
---

<div id="rewind-banner" class="rewind-banner" aria-hidden="true">
  <button class="rewind-dismiss" id="rewind-dismiss" aria-label="Cerrar">×</button>
  <div class="rewind-inner">
    <div class="rewind-icon">◆</div>
    <div class="rewind-content">
      <div class="rewind-heading">REWIND SEMANAL</div>
      <div class="rewind-week">{weekStats.weekLabel}</div>
      <div class="rewind-mini-stats">
        <span><strong>{weekStats.days}</strong> días</span>
        <span class="sep">·</span>
        <span><strong>{weekStats.volume}t</strong> vol</span>
        <span class="sep">·</span>
        <span><strong>{weekStats.sets}</strong> series</span>
      </div>
    </div>
    <button class="rewind-btn" id="rewind-generate">
      <span class="rewind-shimmer-line"></span>
      <span class="rewind-btn-text">COMPARTIR</span>
    </button>
  </div>
</div>

<style is:global>
  .rewind-banner {
    display: none;
    position: relative;
    margin: var(--space-4) 0;
    padding: 1.5px;
    border-radius: 10px;
    background: linear-gradient(90deg, #30d158 0%, #ff9500 50%, #30d158 100%);
    background-size: 200% 100%;
    animation: rewind-border-slide 3s linear infinite;
  }

  @keyframes rewind-border-slide {
    0%   { background-position: 0% 0%; }
    100% { background-position: 200% 0%; }
  }

  .rewind-inner {
    background: var(--bg-secondary);
    border-radius: 9px;
    padding: var(--space-3) var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .rewind-dismiss {
    position: absolute;
    top: 6px;
    right: 8px;
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1;
    padding: 2px 6px;
    cursor: pointer;
    z-index: 1;
    transition: color var(--transition-fast);
  }
  .rewind-dismiss:hover { color: var(--text-primary); }

  .rewind-icon {
    font-size: 1.4rem;
    color: var(--accent-green);
    flex-shrink: 0;
    animation: rewind-icon-pulse 2s ease infinite;
  }

  @keyframes rewind-icon-pulse {
    0%, 100% { opacity: 1;   transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(0.85); }
  }

  .rewind-content {
    flex: 1;
    min-width: 0;
  }

  .rewind-heading {
    font-family: var(--font-display);
    font-size: 0.65rem;
    letter-spacing: 2px;
    color: var(--accent-green);
    margin-bottom: 2px;
  }

  .rewind-week {
    font-size: 0.62rem;
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  .rewind-mini-stats {
    font-size: 0.7rem;
    color: var(--text-secondary);
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .rewind-mini-stats strong { color: var(--text-primary); }
  .rewind-mini-stats .sep   { color: var(--border-light); }

  .rewind-btn {
    position: relative;
    overflow: hidden;
    font-family: var(--font-display);
    font-size: 0.62rem;
    letter-spacing: 1.5px;
    background: var(--accent-green);
    color: var(--text-dark);
    border: none;
    border-radius: 6px;
    padding: var(--space-2) var(--space-3);
    cursor: pointer;
    flex-shrink: 0;
    transition: opacity var(--transition-fast);
  }
  .rewind-btn:hover    { opacity: 0.88; }
  .rewind-btn:disabled { opacity: 0.45; cursor: not-allowed; }

  .rewind-shimmer-line {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.35) 50%, transparent 60%);
    background-size: 200% 100%;
    animation: rewind-shimmer 2.2s ease infinite;
  }
  .rewind-btn:disabled .rewind-shimmer-line { display: none; }

  @keyframes rewind-shimmer {
    0%   { background-position: -100% 0; }
    100% { background-position: 200% 0; }
  }
</style>

<script define:vars={{ weekStats, userName }}>
  const banner      = document.getElementById('rewind-banner');
  const dismissBtn  = document.getElementById('rewind-dismiss');
  const generateBtn = document.getElementById('rewind-generate');
  const btnText     = generateBtn.querySelector('.rewind-btn-text');

  // Show only on Saturdays (or ?rewind=1 for testing)
  const isSaturday = new Date().getDay() === 6;
  const isTest     = new URLSearchParams(location.search).has('rewind');
  const dismissKey = 'rewind-dismissed-' + weekStats.weekLabel;

  if ((isSaturday || isTest) && !localStorage.getItem(dismissKey)) {
    banner.style.display = 'block';
    banner.removeAttribute('aria-hidden');
  }

  dismissBtn.addEventListener('click', () => {
    localStorage.setItem(dismissKey, '1');
    banner.style.display = 'none';
  });

  generateBtn.addEventListener('click', async () => {
    generateBtn.disabled = true;
    btnText.textContent  = 'GENERANDO...';
    try {
      await generateRewindImage();
    } finally {
      generateBtn.disabled = false;
      btnText.textContent  = 'COMPARTIR';
    }
  });

  async function generateRewindImage() {
    await document.fonts.ready;

    const W = 1080, H = 1920;
    const canvas = document.createElement('canvas');
    canvas.width = W; canvas.height = H;
    const ctx = canvas.getContext('2d');

    // ── helpers ──────────────────────────────────────────────────
    function hline(y, color, x0, x1) {
      ctx.strokeStyle = color || '#242424';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(x0 ?? 100, y);
      ctx.lineTo(x1 ?? W - 100, y);
      ctx.stroke();
    }

    function vline(x, y0, y1) {
      ctx.strokeStyle = '#1e1e1e';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(x, y0); ctx.lineTo(x, y1);
      ctx.stroke();
    }

    function drawPill(label, cx, cy, fgColor, bgColor, borderColor, font) {
      ctx.font = font || 'bold 46px Orbitron, monospace';
      const tw = ctx.measureText(label).width;
      const pH = 80, pW = tw + 64, pX = cx - pW/2, pR = 10;
      ctx.fillStyle = bgColor;
      ctx.beginPath();
      ctx.roundRect(pX, cy - pH/2, pW, pH, pR);
      ctx.fill();
      ctx.strokeStyle = borderColor;
      ctx.lineWidth = 1;
      ctx.stroke();
      ctx.fillStyle = fgColor;
      ctx.textBaseline = 'middle';
      ctx.fillText(label, cx, cy);
      ctx.textBaseline = 'alphabetic';
    }

    function bracket(ox, oy, fx, fy) {
      const s = 72, p = 56, sx = fx ? -1 : 1, sy = fy ? -1 : 1;
      ctx.save(); ctx.translate(ox, oy);
      ctx.strokeStyle = '#30d158'; ctx.lineWidth = 3; ctx.lineCap = 'square';
      ctx.beginPath();
      ctx.moveTo(sx*(p+s), sy*p); ctx.lineTo(sx*p, sy*p); ctx.lineTo(sx*p, sy*(p+s));
      ctx.stroke(); ctx.restore();
    }

    // ── BACKGROUND ───────────────────────────────────────────────
    ctx.fillStyle = '#0a0a0a';
    ctx.fillRect(0, 0, W, H);

    // dot grid
    ctx.fillStyle = '#161616';
    for (let x = 54; x < W; x += 54)
      for (let y = 54; y < H; y += 54) {
        ctx.beginPath(); ctx.arc(x, y, 1.6, 0, Math.PI * 2); ctx.fill();
      }

    // ── CORNER BRACKETS ─────────────────────────────────────────
    bracket(0,0,false,false); bracket(W,0,true,false);
    bracket(0,H,false,true);  bracket(W,H,true,true);

    ctx.textAlign = 'center';
    ctx.textBaseline = 'alphabetic';

    // ═══════════════════════════════════════════════════════
    //  ZONE 1 — HEADER  (0 – 450)
    // ═══════════════════════════════════════════════════════
    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 54px Orbitron, monospace';
    ctx.fillText('GYMAPP', W/2, 244);

    // accent dot after logo
    ctx.fillStyle = '#30d158';
    ctx.beginPath(); ctx.arc(W/2 + 175, 228, 8, 0, Math.PI * 2); ctx.fill();

    ctx.fillStyle = '#484848';
    ctx.font = '23px "Space Grotesk", monospace';
    ctx.fillText('REWIND SEMANAL', W/2, 310);

    ctx.fillStyle = '#2e2e2e';
    ctx.font = '20px "Space Grotesk", monospace';
    ctx.fillText(weekStats.weekLabel, W/2, 354);

    hline(410, '#30d158');

    // ═══════════════════════════════════════════════════════
    //  ZONE 2 — HERO DAYS  (410 – 880)
    // ═══════════════════════════════════════════════════════

    // radial glow behind the number (Spotify-inspired)
    const glow = ctx.createRadialGradient(W/2, 680, 0, W/2, 680, 380);
    glow.addColorStop(0, 'rgba(48,209,88,0.10)');
    glow.addColorStop(1, 'rgba(48,209,88,0)');
    ctx.fillStyle = glow;
    ctx.fillRect(0, 420, W, 500);

    ctx.fillStyle = '#30d158';
    ctx.font = 'bold 256px Orbitron, monospace';
    ctx.fillText(weekStats.days.toString(), W/2, 800);

    ctx.fillStyle = '#606060';
    ctx.font = 'bold 26px Orbitron, monospace';
    ctx.fillText('DÍAS ENTRENADOS', W/2, 860);

    hline(910);

    // ═══════════════════════════════════════════════════════
    //  ZONE 3 — STATS 2×2  (910 – 1340)
    // ═══════════════════════════════════════════════════════

    // Row A: VOLUMEN | SERIES
    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 82px Orbitron, monospace';
    ctx.fillText(weekStats.volume + 't', W/4, 1060);
    ctx.font = 'bold 82px Orbitron, monospace';
    ctx.fillText(weekStats.sets + '', W*3/4, 1060);

    ctx.fillStyle = '#484848';
    ctx.font = '20px "Space Grotesk", monospace';
    ctx.fillText('VOLUMEN', W/4, 1108);
    ctx.fillText('SERIES',  W*3/4, 1108);

    vline(W/2, 930, 1140);
    hline(1160);

    // Row B: RACHA | EJERCICIOS
    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 82px Orbitron, monospace';
    ctx.fillText(weekStats.streak + '', W/4, 1298);
    ctx.fillText(weekStats.uniqueExercises + '', W*3/4, 1298);

    ctx.fillStyle = '#484848';
    ctx.font = '20px "Space Grotesk", monospace';
    ctx.fillText('RACHA',       W/4, 1346);
    ctx.fillText('EJERCICIOS',  W*3/4, 1346);

    vline(W/2, 1178, 1370);
    hline(1390);

    // ═══════════════════════════════════════════════════════
    //  ZONE 4 — MÚSCULO DESTACADO  (1390 – 1610)
    // ═══════════════════════════════════════════════════════
    ctx.fillStyle = '#3a3a3a';
    ctx.font = '20px "Space Grotesk", monospace';
    ctx.fillText('MÚSCULO DESTACADO', W/2, 1462);

    if (weekStats.topMuscle) {
      drawPill(weekStats.topMuscle.toUpperCase(), W/2, 1540,
        '#ff9500', '#180d00', '#ff9500', 'bold 48px Orbitron, monospace');
    }

    hline(1618);

    // ═══════════════════════════════════════════════════════
    //  ZONE 5 — PRs  (1618 – 1740)
    // ═══════════════════════════════════════════════════════
    if (weekStats.prs > 0) {
      const label = weekStats.prs === 1 ? '1 RÉCORD NUEVO' : weekStats.prs + ' RÉCORDS NUEVOS';
      drawPill(label, W/2, 1686,
        '#30d158', '#091a10', '#30d158', 'bold 38px Orbitron, monospace');
    } else {
      // sin PRs: mostrar semana total all-time como curiosidad
      ctx.fillStyle = '#282828';
      ctx.font = '20px "Space Grotesk", monospace';
      ctx.fillText('Sin récords esta semana · ¡La próxima!', W/2, 1690);
    }

    // ═══════════════════════════════════════════════════════
    //  ZONE 6 — FOOTER  (1740 – 1920)
    // ═══════════════════════════════════════════════════════
    hline(1768, '#30d158');

    if (userName) {
      ctx.fillStyle = '#383838';
      ctx.font = '26px "Space Grotesk", monospace';
      ctx.fillText(userName, W/2, 1844);
    }

    ctx.fillStyle = '#242424';
    ctx.font = '20px "Space Grotesk", monospace';
    ctx.fillText('Tu progreso, tu récord · GymApp', W/2, 1886);

    // ── DOWNLOAD ────────────────────────────────────────────────
    const dataUrl = canvas.toDataURL('image/jpeg', 0.93);
    const a = document.createElement('a');
    a.href     = dataUrl;
    a.download = 'gymapp-rewind-' + weekStats.weekLabel.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase() + '.jpg';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  }
</script>
