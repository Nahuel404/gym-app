---
import '../styles/global.css';
import PwaHead from '../components/PwaHead.astro';
import { supabase } from '../lib/supabase';

const user = Astro.locals.user;
if (!user || !user.is_trainer) {
  return Astro.redirect('/');
}

// Solicitudes pendientes recibidas
const { data: pendingRequestsData } = await supabase
  .from('trainer_requests')
  .select('id, message, created_at, student:users!trainer_requests_student_id_fkey(id, name, username, avatar_url)')
  .eq('trainer_id', user.id)
  .eq('status', 'pending')
  .order('created_at', { ascending: false });

// Alumnos activos
const { data: studentsData } = await supabase
  .from('trainer_students')
  .select('id, started_at, student:users!trainer_students_student_id_fkey(id, name, username, avatar_url)')
  .eq('trainer_id', user.id)
  .order('started_at', { ascending: false });

const pendingRequests = pendingRequestsData || [];
const students: any[] = [];

// Stats por alumno
for (const rel of studentsData || []) {
  const s = rel.student as any;

  const { data: workoutDates } = await supabase
    .from('workouts')
    .select('workout_date')
    .eq('user_id', s.id);
  const totalWorkouts = new Set(workoutDates?.map(w => w.workout_date)).size;

  const { data: lastWk } = await supabase
    .from('workouts')
    .select('workout_date')
    .eq('user_id', s.id)
    .order('workout_date', { ascending: false })
    .limit(1);

  const { data: volData } = await supabase
    .from('exercise_history')
    .select('weight, reps')
    .eq('user_id', s.id);

  const totalVolume = volData?.reduce((acc, h) => acc + (h.weight * h.reps), 0) || 0;
  const lastDate = lastWk?.[0]?.workout_date || null;

  students.push({
    relation_id: rel.id,
    started_at: rel.started_at,
    ...s,
    total_workouts: totalWorkouts || 0,
    last_workout_date: lastDate,
    total_volume: Math.round(totalVolume)
  });
}

function getTimeAgo(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const hours = Math.floor(diff / 3600000);
  if (hours < 1) return 'hace unos minutos';
  if (hours < 24) return `hace ${hours}h`;
  const days = Math.floor(hours / 24);
  if (days === 1) return 'hace 1 dia';
  return `hace ${days} dias`;
}

function formatDateShort(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('es-AR', { day: 'numeric', month: 'short', year: 'numeric' });
}

function lastWorkoutAgo(dateStr: string | null): string {
  if (!dateStr) return 'Sin entrenamientos';
  const diff = Date.now() - new Date(dateStr + 'T12:00:00').getTime();
  const days = Math.floor(diff / 86400000);
  if (days === 0) return 'Hoy';
  if (days === 1) return 'Hace 1 dia';
  return `Hace ${days} dias`;
}
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mis Alumnos - GymApp</title>
  <PwaHead />
  <style>
    .app-header {
      background: var(--bg-secondary);
      border-bottom: 1px solid var(--border);
      padding: var(--space-3) var(--space-4);
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    @media (min-width: 768px) {
      .app-header {
        padding: var(--space-4) var(--space-6);
      }
    }

    .logo {
      font-family: var(--font-display);
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 2px;
      display: flex;
      align-items: center;
      gap: var(--space-2);
      text-decoration: none;
      color: var(--text-primary);
    }

    .logo-dot {
      width: 6px;
      height: 6px;
      background: var(--accent-green);
      border-radius: 50%;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: var(--space-2);
    }

    @media (min-width: 768px) {
      .header-actions {
        gap: var(--space-3);
      }
    }

    .header-btn {
      padding: var(--space-1) var(--space-2);
      border-radius: 6px;
      font-size: 0.65rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      text-decoration: none;
      transition: all var(--transition-fast);
      border: 1px solid var(--border-light);
      background: transparent;
      color: var(--text-secondary);
      white-space: nowrap;
      cursor: pointer;
    }

    @media (min-width: 768px) {
      .header-btn {
        padding: var(--space-2) var(--space-4);
        font-size: 0.75rem;
        letter-spacing: 1px;
      }
    }

    .header-btn:hover {
      border-color: var(--text-muted);
      color: var(--text-primary);
    }

    main {
      padding: var(--space-4);
      max-width: 900px;
      margin: 0 auto;
    }

    @media (min-width: 768px) {
      main {
        padding: var(--space-6);
      }
    }

    .page-header {
      margin-bottom: var(--space-6);
    }

    .page-header h1 {
      font-family: var(--font-display);
      font-size: 1.25rem;
      letter-spacing: 2px;
      margin-bottom: var(--space-2);
    }

    .page-header p {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .section-label {
      font-family: var(--font-display);
      font-size: 0.7rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: var(--space-3);
      display: flex;
      align-items: center;
      gap: var(--space-2);
    }

    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .section-block {
      margin-bottom: var(--space-6);
    }

    .badge {
      background: var(--accent-orange);
      color: var(--text-dark);
      font-size: 0.65rem;
      font-weight: 700;
      padding: 0.1rem 0.4rem;
      border-radius: 10px;
    }

    /* Request cards */
    .request-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: var(--space-4);
      transition: border-color var(--transition-fast);
    }

    .request-card + .request-card {
      margin-top: var(--space-3);
    }

    .request-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-3);
      flex-wrap: wrap;
    }

    .request-info {
      flex: 1;
      min-width: 0;
    }

    .request-name {
      font-size: 0.875rem;
      font-weight: 500;
    }

    .request-username {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .request-meta {
      font-size: 0.75rem;
      color: var(--text-secondary);
      margin-top: var(--space-1);
    }

    .request-message {
      font-size: 0.8rem;
      color: var(--text-secondary);
      font-style: italic;
      margin-top: var(--space-2);
      padding: var(--space-2) var(--space-3);
      background: var(--bg-secondary);
      border-radius: 6px;
    }

    .request-actions {
      display: flex;
      gap: var(--space-2);
    }

    .btn-sm {
      padding: var(--space-2) var(--space-3);
      border-radius: 6px;
      font-size: 0.75rem;
      font-family: var(--font-body);
      cursor: pointer;
      transition: all var(--transition-fast);
      white-space: nowrap;
      border: none;
    }

    .btn-accept {
      background: var(--accent-green-soft);
      color: var(--accent-green);
      border: 1px solid var(--accent-green);
    }

    .btn-accept:hover {
      background: rgba(48, 209, 88, 0.2);
    }

    .btn-reject {
      background: transparent;
      color: var(--accent-red);
      border: 1px solid var(--accent-red);
    }

    .btn-reject:hover {
      background: var(--accent-red-soft);
    }

    .btn-danger-outline {
      background: transparent;
      color: var(--accent-red);
      border: 1px solid var(--accent-red);
    }

    .btn-danger-outline:hover {
      background: var(--accent-red-soft);
    }

    /* Filter */
    .filter-input {
      width: 100%;
      padding: var(--space-3) var(--space-4);
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text-primary);
      font-size: 0.875rem;
      font-family: var(--font-body);
      margin-bottom: var(--space-4);
      box-sizing: border-box;
    }

    .filter-input:focus {
      outline: none;
      border-color: var(--text-secondary);
    }

    /* Student accordion */
    .student-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      transition: border-color var(--transition-fast);
    }

    .student-card + .student-card {
      margin-top: var(--space-3);
    }

    .student-card:hover {
      border-color: var(--border-light);
    }

    .student-header {
      padding: var(--space-4);
      cursor: pointer;
      user-select: none;
    }

    .student-header-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-3);
    }

    .student-name {
      font-size: 0.875rem;
      font-weight: 500;
    }

    .student-username {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .student-stats {
      display: flex;
      gap: var(--space-4);
      margin-top: var(--space-2);
      flex-wrap: wrap;
    }

    .student-stat {
      font-size: 0.75rem;
      color: var(--text-secondary);
    }

    .student-stat strong {
      color: var(--text-primary);
    }

    .expand-icon {
      font-size: 0.75rem;
      color: var(--text-muted);
      transition: transform var(--transition-fast);
      flex-shrink: 0;
    }

    .student-card.open .expand-icon {
      transform: rotate(90deg);
    }

    .student-body {
      display: none;
      border-top: 1px solid var(--border);
      padding: var(--space-4);
    }

    .student-card.open .student-body {
      display: block;
    }

    .student-actions {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: var(--space-4);
    }

    :global(.workout-day) {
      margin-bottom: var(--space-4);
    }

    :global(.workout-day + .workout-day) {
      padding-top: var(--space-4);
      border-top: 1px solid var(--border);
    }

    :global(.workout-date) {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-primary);
      text-transform: capitalize;
      margin-bottom: var(--space-2);
    }

    :global(.workout-table) {
      width: 100%;
      border-collapse: collapse;
    }

    :global(.workout-table td) {
      padding: var(--space-2) 0;
      vertical-align: top;
      border-bottom: 1px solid var(--border);
    }

    :global(.workout-table tr:last-child td) {
      border-bottom: none;
    }

    :global(.workout-table .td-exercise) {
      color: var(--text-primary);
      font-size: 0.8rem;
      font-weight: 500;
      padding-right: var(--space-3);
    }

    :global(.workout-table .td-sets) {
      color: var(--text-muted);
      font-size: 0.75rem;
      text-align: right;
      white-space: nowrap;
    }

    :global(.workout-total) {
      font-size: 0.7rem;
      color: var(--text-muted);
      text-align: right;
      margin-top: var(--space-2);
      padding-top: var(--space-2);
      border-top: 1px solid var(--border);
    }

    :global(.workout-total span) {
      color: var(--accent-green);
      font-family: var(--font-display);
    }

    .view-full-link {
      display: inline-block;
      margin-top: var(--space-3);
      font-size: 0.8rem;
      color: var(--text-secondary);
      text-decoration: none;
      transition: color var(--transition-fast);
    }

    .view-full-link:hover {
      color: var(--text-primary);
    }

    :global(.loading-text) {
      color: var(--text-muted);
      font-size: 0.8rem;
      padding: var(--space-3);
      text-align: center;
    }

    .empty-state {
      text-align: center;
      padding: var(--space-8) var(--space-4);
      color: var(--text-muted);
    }

    .empty-state-text {
      font-size: 0.875rem;
    }
  </style>
</head>
<body>
  <header class="app-header">
    <a href="/" class="logo">
      GYMAPP
      <span class="logo-dot"></span>
    </a>
    <div class="header-actions">
      <div class="nav-links" id="navLinks">
        <a href="/favorites" class="header-btn">Favoritos</a>
        <a href="/history" class="header-btn">Historial</a>
        <a href="/trainers" class="header-btn">Entrenadores</a>
        <a href="/settings" class="header-btn">Configuracion</a>
      </div>
      <button class="nav-toggle" id="navToggle" aria-label="Menú">&#9776;</button>
    </div>
  </header>

  <main>
    <div class="page-header">
      <h1>MIS ALUMNOS</h1>
      <p>Gestiona tus alumnos y revisa su progreso</p>
    </div>

    <!-- Solicitudes pendientes -->
    {pendingRequests.length > 0 && (
      <div class="section-block" id="requestsSection">
        <div class="section-label">
          Solicitudes Recibidas <span class="badge">{pendingRequests.length}</span>
        </div>
        {pendingRequests.map(req => {
          const s = req.student as any;
          return (
            <div class="request-card" data-request-id={req.id}>
              <div class="request-row">
                <div class="request-info">
                  <div class="request-name">{s.name} <span class="request-username">@{s.username}</span></div>
                  <div class="request-meta">{getTimeAgo(req.created_at)}</div>
                </div>
                <div class="request-actions">
                  <button class="btn-sm btn-accept accept-btn" data-id={req.id}>Aceptar</button>
                  <button class="btn-sm btn-reject reject-btn" data-id={req.id}>Rechazar</button>
                </div>
              </div>
              {req.message && <div class="request-message">"{req.message}"</div>}
            </div>
          );
        })}
      </div>
    )}

    <!-- Alumnos activos -->
    <div class="section-block">
      <div class="section-label">Alumnos Activos ({students.length})</div>

      {students.length > 3 && (
        <input type="text" class="filter-input" id="filterInput" placeholder="Filtrar alumno..." />
      )}

      <div id="studentsList">
        {students.length > 0 ? (
          students.map(s => (
            <div class="student-card" data-student-id={s.id} data-name={s.name.toLowerCase()} data-username={s.username.toLowerCase()}>
              <div class="student-header">
                <div class="student-header-row">
                  <div>
                    <div class="student-name">
                      <span class="expand-icon">&#9656;</span>
                      {s.name} <span class="student-username">@{s.username}</span>
                    </div>
                    <div class="student-stats">
                      <span class="student-stat">Desde: <strong>{formatDateShort(s.started_at)}</strong></span>
                      <span class="student-stat">Ultimo entreno: <strong>{lastWorkoutAgo(s.last_workout_date)}</strong></span>
                      <span class="student-stat"><strong>{s.total_workouts}</strong> entrenamientos</span>
                      <span class="student-stat"><strong>{(s.total_volume / 1000).toFixed(1)}t</strong> volumen</span>
                    </div>
                  </div>
                </div>
              </div>
              <div class="student-body" id={`body-${s.id}`}>
                <div class="student-actions">
                  <a href={`/my-students/${s.id}`} class="view-full-link">Ver historial completo &rarr;</a>
                  <button class="btn-sm btn-danger-outline remove-btn" data-id={s.relation_id} data-name={s.name}>Remover</button>
                </div>
                <div class="loading-text" id={`workouts-${s.id}`}>Cargando entrenamientos...</div>
              </div>
            </div>
          ))
        ) : (
          <div class="empty-state">
            <div class="empty-state-text">No tienes alumnos aun.</div>
          </div>
        )}
      </div>
    </div>
  </main>

  <script>
    // Mobile nav toggle
    document.getElementById('navToggle')?.addEventListener('click', (e) => {
      e.stopPropagation();
      document.getElementById('navLinks')?.classList.toggle('open');
    });
    document.addEventListener('click', () => document.getElementById('navLinks')?.classList.remove('open'));

    // Accept/reject requests
    document.querySelectorAll('.accept-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).dataset.id!;
        const res = await fetch(`/api/trainer-requests?id=${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: 'accepted' })
        });
        if (res.ok) {
          window.location.reload();
        }
      });
    });

    document.querySelectorAll('.reject-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).dataset.id!;
        if (!confirm('Rechazar esta solicitud?')) return;
        const res = await fetch(`/api/trainer-requests?id=${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: 'rejected' })
        });
        if (res.ok) {
          btn.closest('.request-card')?.remove();
        }
      });
    });

    // Remove student
    document.querySelectorAll('.remove-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).dataset.id!;
        const name = (btn as HTMLElement).dataset.name!;
        if (!confirm(`Remover a ${name} como alumno?`)) return;
        const res = await fetch(`/api/trainer-students?id=${id}`, { method: 'DELETE' });
        if (res.ok) {
          btn.closest('.student-card')?.remove();
        }
      });
    });

    // Filter
    const filterInput = document.getElementById('filterInput') as HTMLInputElement | null;
    if (filterInput) {
      filterInput.addEventListener('input', () => {
        const q = filterInput.value.toLowerCase();
        document.querySelectorAll('.student-card').forEach(card => {
          const name = (card as HTMLElement).dataset.name || '';
          const username = (card as HTMLElement).dataset.username || '';
          (card as HTMLElement).style.display = (name.includes(q) || username.includes(q)) ? '' : 'none';
        });
      });
    }

    // Accordion + lazy load workouts
    const loadedStudents = new Set<string>();

    document.querySelectorAll('.student-header').forEach(header => {
      header.addEventListener('click', async () => {
        const card = header.closest('.student-card') as HTMLElement;
        const studentId = card.dataset.studentId!;
        const isOpen = card.classList.toggle('open');

        if (isOpen && !loadedStudents.has(studentId)) {
          loadedStudents.add(studentId);
          const container = document.getElementById(`workouts-${studentId}`)!;

          try {
            const res = await fetch(`/api/trainer-students?student_id=${studentId}&days=60`);
            const { workouts } = await res.json();

            if (!workouts || workouts.length === 0) {
              container.innerHTML = '<div class="loading-text">Sin entrenamientos recientes</div>';
              return;
            }

            // Agrupar workouts por fecha (mismo día = 1 entrenamiento)
            const byDate = new Map();
            for (const w of workouts) {
              if (!byDate.has(w.workout_date)) byDate.set(w.workout_date, []);
              byDate.get(w.workout_date).push(...(w.exercise_history || []));
            }

            const recentDates = Array.from(byDate.keys()).slice(0, 5);
            let html = '';

            for (const dateKey of recentDates) {
              const allHistory = byDate.get(dateKey);
              const date = new Date(dateKey + 'T12:00:00').toLocaleDateString('es-AR', {
                weekday: 'long', day: 'numeric', month: 'short', year: 'numeric'
              });

              // Group exercises
              const exMap = new Map();
              for (const h of allHistory) {
                const ex = h.exercises;
                const parts = [h.variant_equipment, h.variant_grip, h.variant_position].filter(Boolean);
                const variant = parts.length > 0 ? ` · ${parts.join(' · ')}` : '';
                const key = `${ex.id}${variant}`;
                if (!exMap.has(key)) exMap.set(key, []);
                exMap.get(key).push({ ...h, displayName: `${ex.name}${variant}` });
              }

              let rows = '';
              let dayVolume = 0;
              for (const [, sets] of exMap) {
                const setsStr = sets.map((s) => `${s.weight}×${s.reps}`).join(' · ');
                dayVolume += sets.reduce((a, s) => a + s.weight * s.reps, 0);
                rows += `<tr>
                  <td class="td-exercise">${sets[0].displayName}</td>
                  <td class="td-sets">${setsStr}</td>
                </tr>`;
              }

              html += `
                <div class="workout-day">
                  <div class="workout-date">${date}</div>
                  <table class="workout-table"><tbody>${rows}</tbody></table>
                  <div class="workout-total">Volumen: <span>${(dayVolume / 1000).toFixed(1)}t</span></div>
                </div>
              `;
            }

            container.innerHTML = html;
          } catch {
            container.innerHTML = '<div class="loading-text">Error al cargar entrenamientos</div>';
          }
        }
      });
    });
  </script>
</body>
</html>
